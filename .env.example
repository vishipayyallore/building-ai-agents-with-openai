# Local environment configuration
#
# Copy this template into config/, then fill in secrets:
#
#   Copy-Item .env.example config\.env
#
# Never commit `config/.env`. See config/README.md.

OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1-mini

# Provider selection (planned for Session 3+; current Session 1 code uses OpenAI)
LLM_PROVIDER=openai

# Azure OpenAI (planned optional Session 3 provider extension; not wired in Session 1)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-10-21

# AWS Bedrock (planned Session 3 core path; not wired in Session 1)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=qwen.qwen3-coder-480b

# Weather MCP tool (optional — demo fallback when unset)
OPENWEATHER_API_KEY=

# Backend
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
