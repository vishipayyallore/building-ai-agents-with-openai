# OpenAI (required for Demo 1 agent)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1-mini

# Provider selection (Session 3+ supports openai, azure_openai, or bedrock)
LLM_PROVIDER=openai

# Azure OpenAI (optional Session 3 provider extension; required when LLM_PROVIDER=azure_openai)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-10-21

# AWS Bedrock (Session 3 core path; required when LLM_PROVIDER=bedrock)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=qwen.qwen3-coder-480b

# Weather MCP tool (optional — demo fallback when unset)
OPENWEATHER_API_KEY=

# Backend
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
